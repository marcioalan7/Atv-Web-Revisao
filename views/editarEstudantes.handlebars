<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar Estudante</title>
</head>
<body>
<h1>Edição de Estudantes</h1>

<form action="/estudantes/{{estudante.id}}?_method=PUT" method="POST">

  <div>
    <label>Nome:</label>
    <input type="text" name="nome" value="{{estudante.nome}}">
  </div>

  <br>

  <div>
    <label>Idade:</label>
    <input type="number" name="ano" value="{{estudante.idade}}">
  </div>

  <br>

  <button type="submit">
    Editar
  </button>

</form>
</body>
</html>